# HTTP bind
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# Required: Mattermost incoming webhook URL (treat as secret)
MATTERMOST_URL=https://your-mattermost.example.com/hooks/your-generated-key

# Optional: override default channel for this webhook
MATTERMOST_CHANNEL=alerts

MATTERMOST_TIMEOUT_SECONDS=10

# TLS for Mattermost outgoing HTTPS (default true). Set false only for dev/test with bad certs.
# MATTERMOST_VERIFY_SSL=false
# MATTERMOST_SSL_CA_BUNDLE=/path/to/internal-ca.pem

# Optional: full base URL of SUSE Observability / StackState UI (overrides links from payload)
# SUSE_OBS_BASE_URL=https://stackstate.example.com

# Close events (spec type=close): separate short template (default: summary only)
# CLOSE_MESSAGE_TEMPLATE={{ summary }}

# Open-alert throttling: the app default is OFF (every open → Mattermost immediately).
# Uncomment to enable: first open per monitor → immediate; further opens in the window
# (same monitor.identifier or name) → one summarized Mattermost post when the window ends.
# In-memory only — use replicas: 1 when batching is enabled.
# MONITORING_BATCH_ENABLED=true
# MONITORING_BATCH_WINDOW_SECONDS=60

# Message body: inline template (multiline) OR path to a file
# MESSAGE_TEMPLATE_PATH=/etc/suseobs/message.md
# MESSAGE_TEMPLATE='**Alert** {{ summary }}'

# Optional: shared secret — must match SUSE Observability / StackState webhook token if used.
# Accepts X-StackState-Webhook-Token (spec), or Authorization: Bearer, or X-Webhook-Token.
# WEBHOOK_AUTH_TOKEN=your-random-token
